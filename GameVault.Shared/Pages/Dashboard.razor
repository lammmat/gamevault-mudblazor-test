@page "/"
@inject IGameService GameService

<PageTitle>GameVault – Dashboard</PageTitle>

<MudText Typo="Typo.h4" Class="mb-6 gv-section-title">Dashboard</MudText>

@if (_stats is null)
{
    <MudGrid>
        @for (int i = 0; i < 4; i++)
        {
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="80px" />
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
}
else
{
    <MudGrid>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4 d-flex align-center gap-4 gv-stat-card gv-accent-primary" Elevation="2">
                <MudIcon Icon="@Icons.Material.Filled.VideogameAsset" Color="Color.Primary" Size="Size.Large" />
                <div>
                    <MudText Typo="Typo.h4">@_stats.TotalGames</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Default">Total Games</MudText>
                </div>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4 d-flex align-center gap-4 gv-stat-card gv-accent-success" Elevation="2">
                <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Success" Size="Size.Large" />
                <div>
                    <MudText Typo="Typo.h4">@_stats.AverageRating.ToString("F1")</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Default">Avg Rating</MudText>
                </div>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4 d-flex align-center gap-4 gv-stat-card gv-accent-info" Elevation="2">
                <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Color="Color.Info" Size="Size.Large" />
                <div>
                    <MudText Typo="Typo.h4">@_stats.GamesByStatus.GetValueOrDefault("Playing", 0)</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Default">Currently Playing</MudText>
                </div>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4 d-flex align-center gap-4 gv-stat-card gv-accent-warning" Elevation="2">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Warning" Size="Size.Large" />
                <div>
                    <MudText Typo="Typo.h4">@_stats.GamesByStatus.GetValueOrDefault("Completed", 0)</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Default">Completed</MudText>
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudGrid Class="mt-6">
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-4 gv-section-title">Top Genres</MudText>
                @foreach (var genre in _stats.GamesByGenre)
                {
                    <div class="mb-3">
                        <div class="d-flex justify-space-between mb-1">
                            <MudText Typo="Typo.body2">@genre.Key</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Primary">@genre.Value</MudText>
                        </div>
                        <MudProgressLinear Value="@((double)genre.Value / _stats.GamesByGenre.Values.Max() * 100)"
                                           Color="Color.Primary" Rounded="true" Size="Size.Medium" />
                    </div>
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-4 gv-section-title">Games by Platform</MudText>
                @foreach (var platform in _stats.GamesByPlatform)
                {
                    <div class="mb-3">
                        <div class="d-flex justify-space-between mb-1">
                            <MudText Typo="Typo.body2">@platform.Key</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@platform.Value</MudText>
                        </div>
                        <MudProgressLinear Value="@((double)platform.Value / _stats.GamesByPlatform.Values.Max() * 100)"
                                           Color="Color.Secondary" Rounded="true" Size="Size.Medium" />
                    </div>
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-4 gv-section-title">Status Breakdown</MudText>
                @foreach (var status in _stats.GamesByStatus)
                {
                    <div class="mb-3">
                        <div class="d-flex justify-space-between mb-1">
                            <MudText Typo="Typo.body2">@status.Key</MudText>
                            <MudText Typo="Typo.body2">@status.Value</MudText>
                        </div>
                        <MudProgressLinear Value="@((double)status.Value / _stats.TotalGames * 100)"
                                           Color="@GetStatusColor(status.Key)" Rounded="true" Size="Size.Medium" />
                    </div>
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-4 gv-section-title">Quick Actions</MudText>
                <div class="d-flex flex-column gap-3">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.VideogameAsset"
                               Href="/catalog" FullWidth="true">Browse Game Catalog</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Info" StartIcon="@Icons.Material.Filled.FilterList"
                               Href="/catalog?status=Playing" FullWidth="true">Currently Playing</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Warning" StartIcon="@Icons.Material.Filled.Bookmark"
                               Href="/catalog?status=Backlog" FullWidth="true">View Backlog</MudButton>
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    private GameStats? _stats;

    protected override async Task OnInitializedAsync()
    {
        _stats = await GameService.GetStatsAsync();
    }

    private Color GetStatusColor(string status) => status switch
    {
        "Playing"   => Color.Info,
        "Completed" => Color.Success,
        "Dropped"   => Color.Error,
        _           => Color.Warning
    };
}
