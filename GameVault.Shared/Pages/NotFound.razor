@page "/not-found"

<PageTitle>Not Found – GameVault</PageTitle>

<div class="d-flex flex-column align-center justify-center" style="min-height:60vh; text-align:center;">
    <MudIcon Icon="@Icons.Material.Filled.SearchOff" Style="font-size:96px; color:#7e6fff; opacity:0.5;" Class="mb-4" />
    <MudText Typo="Typo.h3" Class="mb-2">404</MudText>
    <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mb-6">This page doesn't exist in our vault.</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/" StartIcon="@Icons.Material.Filled.Home">
        Return to Dashboard
    </MudButton>
</div>
