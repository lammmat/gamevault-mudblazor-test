<MudCard Elevation="2" Style="cursor:pointer; height:100%" @onclick="() => OnClick.InvokeAsync(Game.Id)">
    <div style="background: linear-gradient(135deg, #1e1e2d 0%, #2d2d4e 100%);
                height:180px; display:flex; align-items:center; justify-content:center;">
        <MudText Typo="Typo.h6" Align="Align.Center" Class="px-3" Style="color:#7e6fff; word-break:break-word">
            @Game.Title
        </MudText>
    </div>
    <MudCardContent>
        <div class="d-flex justify-space-between align-center mb-1">
            <MudText Typo="Typo.subtitle1"><b>@Game.Title</b></MudText>
            <MudChip T="string" Color="Color.Warning" Size="Size.Small" Icon="@Icons.Material.Filled.Star">
                @Game.Rating.ToString("F1")
            </MudChip>
        </div>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
            @Game.Developer · @Game.ReleaseYear
        </MudText>
        <div class="d-flex flex-wrap gap-1 mb-2">
            @foreach (var genre in Game.Genres.Take(2))
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">@genre</MudChip>
            }
        </div>
        <div class="d-flex flex-wrap gap-1">
            @foreach (var platform in Game.Platforms.Take(3))
            {
                <MudChip T="string" Size="Size.Small" Variant="Variant.Text">@platform</MudChip>
            }
        </div>
    </MudCardContent>
</MudCard>

@code {
    [Parameter, EditorRequired] public Game Game { get; set; } = null!;
    [Parameter] public EventCallback<int> OnClick { get; set; }
}
