{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "🌐 GameVault Web",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build: GameVault.Web",
      "program": "${workspaceFolder}/GameVault.Web/bin/Debug/net10.0/GameVault.Web.dll",
      "args": [],
      "cwd": "${workspaceFolder}/GameVault.Web",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
    {
      "name": "🖥️ GameVault MAUI (Windows)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build: GameVault.Maui (Windows)",
      "program": "${workspaceFolder}/GameVault.Maui/bin/Debug/net10.0-windows10.0.19041.0/win-x64/GameVault.Maui.exe",
      "args": [],
      "cwd": "${workspaceFolder}/GameVault.Maui",
      "stopAtEntry": false,
      "console": "externalTerminal"
    }
  ]
}
